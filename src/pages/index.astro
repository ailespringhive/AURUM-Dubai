---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
---

<BaseLayout title="AURUM Dubai — Luxury Tours & Exclusive Experiences" description="Experience the pinnacle of luxury travel in Dubai. Curated private tours, desert safaris, yacht cruises, and VIP experiences.">

  <!-- Preloader -->
  <div class="preloader" id="preloader">
    <div class="preloader-text">
      <span style="animation-delay:0.1s">A</span><span style="animation-delay:0.15s">U</span><span style="animation-delay:0.2s">R</span><span style="animation-delay:0.25s">U</span><span style="animation-delay:0.3s">M</span>
    </div>
  </div>

  <Navbar />

  <!-- Hero -->
  <section class="hero">
    <img src="/images/dubai-hero.png" alt="Dubai skyline at golden hour">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="container">
        <p class="hero-eyebrow">Luxury Travel Concierge</p>
        <h1 class="hero-title">Discover<br><em>Dubai</em></h1>
        <p class="hero-desc">Bespoke journeys through the world's most extraordinary city. Every moment crafted, every detail perfected.</p>
        <div class="hero-btns">
          <a href="/tours" class="btn-primary">Explore Tours →</a>
          <a href="/experiences" class="btn-secondary">Our Experiences</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-num">7</div>
          <div class="stat-label">Star Destinations</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">2,500+</div>
          <div class="stat-label">Happy Travelers</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">98%</div>
          <div class="stat-label">Satisfaction Rate</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">50+</div>
          <div class="stat-label">Unique Experiences</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Intro -->
  <section class="intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-img reveal">
          <img src="/images/burj-al-arab.png" alt="Burj Al Arab">
          <div class="intro-badge">
            <div class="num">15+</div>
            <div class="lbl">Years of Excellence</div>
          </div>
        </div>
        <div class="intro-content reveal">
          <p class="intro-overline">About Aurum Dubai</p>
          <h2 class="intro-title">Where Luxury Meets the Extraordinary</h2>
          <p class="intro-text">Aurum Dubai is the region's most exclusive travel concierge, crafting bespoke journeys for the world's most discerning travelers.</p>
          <p class="intro-text">We believe luxury is not a price tag — it's an emotion. Our experiences are designed to leave you breathless.</p>
          <div class="intro-stats-row">
            <div class="intro-stat-item"><div class="n">2,500+</div><div class="t">Happy Travelers</div></div>
            <div class="intro-stat-item"><div class="n">98%</div><div class="t">Satisfaction</div></div>
            <div class="intro-stat-item"><div class="n">50+</div><div class="t">Experiences</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experiences Preview -->
  <section class="experiences">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-overline">Curated Experiences</p>
        <h2 class="section-title">Moments That Define Luxury</h2>
        <p class="section-subtitle">Each experience is a masterpiece, handcrafted to immerse you in the opulence that only Dubai can offer.</p>
      </div>
      <div class="exp-grid">
        <div class="exp-card reveal">
          <img src="/images/desert-safari.png" alt="Desert safari">
          <div class="exp-card-overlay"></div>
          <div class="exp-card-body">
            <div class="exp-card-num">01</div>
            <h3 class="exp-card-title">Royal Desert Safari</h3>
            <p class="exp-card-desc">Private dunes, VIP camp, falconry, and gourmet dining under the stars.</p>
          </div>
        </div>
        <div class="exp-card reveal">
          <img src="/images/dubai-marina.png" alt="Yacht cruise">
          <div class="exp-card-overlay"></div>
          <div class="exp-card-body">
            <div class="exp-card-num">02</div>
            <h3 class="exp-card-title">Private Yacht Cruise</h3>
            <p class="exp-card-desc">Sail the Arabian Gulf with a personal chef and panoramic views.</p>
          </div>
        </div>
        <div class="exp-card reveal">
          <img src="/images/luxury-dining.png" alt="Fine dining">
          <div class="exp-card-overlay"></div>
          <div class="exp-card-body">
            <div class="exp-card-num">03</div>
            <h3 class="exp-card-title">Michelin Dining</h3>
            <p class="exp-card-desc">Exclusive rooftop restaurants with curated tasting menus.</p>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:48px;">
        <a href="/experiences" class="btn-primary">View All Experiences →</a>
      </div>
    </div>
  </section>

  <!-- Tours Preview -->
  <section class="tours" style="padding-bottom:100px;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-overline">Signature Tours</p>
        <h2 class="section-title">Journeys Crafted for the Elite</h2>
        <p class="section-subtitle">Our tours blend iconic landmarks with hidden gems.</p>
      </div>
      <div class="tour-block reveal">
        <div class="tour-img">
          <img src="/images/palm-jumeirah.png" alt="Palm Jumeirah">
          <div class="tour-tag">Most Popular</div>
        </div>
        <div>
          <p class="tour-label">⏱ Full Day · 10 Hours</p>
          <h3 class="tour-name">The Grand Dubai Experience</h3>
          <p class="tour-desc">An unparalleled full-day journey through Dubai's most iconic landmarks.</p>
          <div class="tour-features">
            <div class="tour-feat"><span class="icon">◆</span> Burj Khalifa VIP</div>
            <div class="tour-feat"><span class="icon">◆</span> Palm Jumeirah</div>
            <div class="tour-feat"><span class="icon">◆</span> Private Rolls Royce</div>
            <div class="tour-feat"><span class="icon">◆</span> Sunset Cruise</div>
          </div>
          <div class="tour-price-row">
            <span class="tour-price-from">From</span>
            <span class="tour-price-amount">$1,299</span>
            <span class="tour-price-per">/ person</span>
          </div>
          <a href="/tours" class="btn-primary">View All Tours →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-bg"><img src="/images/dubai-fountain.png" alt="Dubai Fountain"></div>
    <div class="cta-overlay"></div>
    <div class="container">
      <div class="cta-inner reveal">
        <h2 class="cta-title">Begin Your Dubai Story</h2>
        <p class="cta-text">Subscribe to receive exclusive offers, curated itineraries, and insider access to Dubai's finest.</p>
        <form class="cta-form" onsubmit="event.preventDefault();">
          <input type="email" class="cta-input" placeholder="Enter your email" required>
          <button type="submit" class="cta-submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
  <BackToTop />

  <script is:inline>
    window.addEventListener('load', () => { setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 1600); });
  </script>

</BaseLayout>
